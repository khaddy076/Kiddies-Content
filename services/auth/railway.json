{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd ../.. && npm install && npx turbo run build --filter=@kiddies/auth",
    "watchPatterns": ["services/auth/**", "packages/**"]
  },
  "deploy": {
    "startCommand": "node services/auth/dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
