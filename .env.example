# ============================================================
# KIDDIES CONTENT - Environment Variables Template
# Copy this file to .env and fill in values
# ============================================================

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://kiddies:kiddies_secret@localhost:5432/kiddies_content
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Auth ───────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ── YouTube API ────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
YOUTUBE_OAUTH_CLIENT_ID=your_oauth_client_id
YOUTUBE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/parent/platforms/youtube/callback

# ── Firebase (Push Notifications) ─────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# ── Google Cloud (AI Safety Scoring) ──────────────────────
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
GOOGLE_CLOUD_KEY_FILE=./keys/gcp-service-account.json

# ── Encryption ─────────────────────────────────────────────
ENCRYPTION_KEY=32_byte_hex_string_for_aes_256_gcm
ENCRYPTION_IV_LENGTH=16

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@kiddies-content.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Kiddies Content <noreply@kiddies-content.com>

# ── Services ───────────────────────────────────────────────
API_PORT=3001
AUTH_PORT=3002
API_URL=http://localhost:3001
AUTH_URL=http://localhost:3002
WEB_URL=http://localhost:3000
NODE_ENV=development

# ── Recommendation Engine ──────────────────────────────────
RECOMMENDATION_REFRESH_CRON=0 */6 * * *
RECOMMENDATION_COLD_START_THRESHOLD=5
RECOMMENDATION_COMMUNITY_MIN_PARENTS=10
RECOMMENDATION_TOP_N=30

# ── Content Safety ─────────────────────────────────────────
AI_SAFETY_SCORE_THRESHOLD=0.7
YOUTUBE_SAFE_SEARCH=strict

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_API_MAX=1000
RATE_LIMIT_API_WINDOW=60000
